# Live readiness environment template.
#
# Create or reuse $HOME/.vivarium/live/live-readiness.local.env before filling
# values with the guided local setup files:
#
#   vivarium setup live
#
# Add --confirm-write to the guided setup after you have the real local inputs
# and want it to write provider profiles, credentials, and the evidence skeleton
# in one guarded step.
#
# Lower-level alternatives when you do not want the combined wizard:
#
#   vivarium connect init
#   vivarium connect signup
#   vivarium connect wizard
#
# Do not commit a filled copy or real secrets.
#
# After filling these values, use the connect dashboard and setup handoff
# from the-agent:
#
#   vivarium connect
#   vivarium connect fill
#   vivarium connect setup --confirm-write
#   vivarium connect smoke
#   vivarium proof init
#   vivarium proof
#
# Finish with the readiness gate:
#
#   vivarium doctor --live \
#     --agent-root "$HOME/.vivarium/vivarium-agent" \
#     --world-root "$HOME/.vivarium/the-world"

# Naming gate: public repository names used by doctor checks and GitHub links.
export VIVARIUM_AGENT_REPO_NAME="<final-agent-repo>"
export VIVARIUM_WORLD_REPO_NAME="<final-world-repo>"

# GitHub/public release: safe repo metadata plus a real token for GitHub smoke
# checks. The node IDs identify the canonical world repository and Discussion
# category; they are not provider secrets.
export VIVARIUM_GITHUB_OWNER="<github-owner-or-org>"
export VIVARIUM_GITHUB_REPOSITORY_ID="<world-repository-node-id>"
export VIVARIUM_GITHUB_DISCUSSION_CATEGORY_ID="<discussion-category-node-id>"
export GITHUB_TOKEN="<redacted-github-token>"
export GH_TOKEN="$GITHUB_TOKEN"

# World subscriptions: public canonical world plus private/internal fork refs for
# retrieval and second-install pull checks. Repository URLs are metadata unless
# the private ref embeds credentials, which it should not.
export VIVARIUM_WORLD_SUBSCRIPTIONS_PATH="$HOME/.vivarium/live/world-subscriptions.json"
export VIVARIUM_CANONICAL_WORLD_REF="<canonical-world-remote-url>"
export VIVARIUM_PRIVATE_WORLD_REF="<private-world-remote-url>"

# Provider keys/models: real LLM credentials and model coordinates. Public
# provider model defaults are filled so first-time setup starts with keys, not
# model hunting. Model names, base URLs, and context windows are routing
# metadata; API keys are secrets.
# The private OAI-compatible provider is the internal/fine-tune path required by
# the v1 readiness gate, separate from Anthropic and OpenRouter.
export ANTHROPIC_API_KEY="<redacted-anthropic-key>"
export OPENROUTER_API_KEY="<redacted-openrouter-key>"
export VIVARIUM_OAI_COMPAT_API_KEY="<redacted-private-oai-compatible-key>"
export VIVARIUM_OAI_COMPAT_BASE_URL="<private-oai-compatible-base-url>"
export VIVARIUM_OAI_COMPAT_MODEL="<private-fine-tune-model>"
export VIVARIUM_OAI_COMPAT_CONTEXT_WINDOW="<private-context-window>"

# Provider profiles: local profile names and the JSON path used to save reusable
# provider routing. Profiles point at env var names; they do not store plaintext
# provider keys.
export VIVARIUM_PROVIDER_PROFILES_PATH="$HOME/.vivarium/live/provider-profiles.json"
export VIVARIUM_ANTHROPIC_PROVIDER_PROFILE="anthropic-main"
export VIVARIUM_ANTHROPIC_MODEL="claude-sonnet-4-6"
export VIVARIUM_ANTHROPIC_CONTEXT_WINDOW="1000000"
export VIVARIUM_OPENROUTER_PROVIDER_PROFILE="openrouter"
export VIVARIUM_OPENROUTER_MODEL="openrouter/auto"
export VIVARIUM_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
export VIVARIUM_OPENROUTER_CONTEXT_WINDOW="2000000"
export VIVARIUM_PRIVATE_OAI_COMPAT_PROVIDER_PROFILE="private-finetune"

# Encrypted credential store and internal API smoke target: the master key
# decrypts the local store, the credential value is written into that encrypted
# store, and the health URL proves the dispatcher can inject it without printing
# the secret.
export VIVARIUM_CREDENTIALS_PATH="$HOME/.vivarium/live/credentials.enc"
export VIVARIUM_CREDENTIALS_MASTER_KEY="<local-master-key>"
export VIVARIUM_INTERNAL_API_CREDENTIAL_NAME="INTERNAL_API_TOKEN"
export VIVARIUM_INTERNAL_API_CREDENTIAL_VALUE="<redacted-internal-api-token>"
export VIVARIUM_INTERNAL_API_HEALTH_URL="<internal-api-health-url>"

# Live v1 evidence manifest: inspectable evidence links for real goals, provider
# smokes, Dream artifacts, public contribution flow, curation stats, and the
# required two-week improvement check.
export VIVARIUM_V1_EVIDENCE_PATH="$HOME/.vivarium/live/v1-evidence.json"
