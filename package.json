{
  "name": "the-agent",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "format:check": "oxfmt --check package.json .oxlintrc.jsonc .oxfmtrc.json knip.json turbo.json tsconfig.base.json scripts/tooling.test.ts scripts/workflows.test.ts scripts/reference-docs.test.ts",
    "knip": "knip --include dependencies,unlisted,unresolved --no-config-hints",
    "lint": "bun run scripts/lint.ts && oxlint .",
    "record:local-e2e-demo": "node scripts/record-local-e2e-demo.cjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "verify:sqlite-stack": "node scripts/verify-better-sqlite3.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.3",
    "drizzle-kit": "^0.31.10",
    "knip": "^5.67.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
